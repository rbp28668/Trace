@page
@model Trace.Web.Pages.Competitions.IndexModel
@{
    ViewData["Title"] = "Competitions";
}

<h1>Competitions &amp; classes</h1>
<p class="text-muted">Add, edit and delete competitions and their classes here. Use the buttons on each competition to manage its days, fleet, tasks and scoring.</p>

@if (!Model.Competitions.Any() && Model.EditCompetition != 0)
{
    <div class="alert alert-info">No competitions yet. Add one to get started.</div>
}

@foreach (var c in Model.Competitions)
{
    <div class="card mb-3">
        <div class="card-body">
            @if (Model.EditCompetition == c.Id)
            {
                <form method="post" asp-page-handler="UpdateCompetition" asp-route-id="@c.Id" class="row g-2 align-items-end">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="col-md-3">
                        <label class="form-label">Name</label>
                        <input asp-for="Competition.Name" value="@c.Name" class="form-control" />
                        <span asp-validation-for="Competition.Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Site</label>
                        <input asp-for="Competition.Site" value="@c.Site" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Start</label>
                        <input asp-for="Competition.StartDate" value="@c.StartDate.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">End</label>
                        <input asp-for="Competition.EndDate" value="@c.EndDate.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="col-md-2 form-check ms-2">
                        <input asp-for="Competition.MakeActive" checked="@c.IsActive" class="form-check-input" />
                        <label asp-for="Competition.MakeActive" class="form-check-label">Active</label>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary btn-sm">Save</button>
                        <a asp-page="Index" class="btn btn-secondary btn-sm">Cancel</a>
                    </div>
                </form>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h2 class="h5 mb-1">
                            @c.Name
                            @if (c.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </h2>
                        <p class="text-muted mb-2">
                            @c.Site
                            <span class="mx-1">·</span>
                            @c.StartDate.ToString("yyyy-MM-dd") – @c.EndDate.ToString("yyyy-MM-dd")
                        </p>
                    </div>
                    <div class="text-end">
                        <a asp-page="/Days/Index" asp-route-competitionId="@c.Id" class="btn btn-sm btn-outline-secondary">Days</a>
                        <a asp-page="Index" asp-route-editCompetition="@c.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        @if (!c.IsActive)
                        {
                            <form method="post" asp-page-handler="Activate" asp-route-id="@c.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-success">Make active</button>
                            </form>
                        }
                        <form method="post" asp-page-handler="DeleteCompetition" asp-route-id="@c.Id" class="d-inline"
                              onsubmit="return confirm('Delete this competition and all its classes, days and tasks?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </div>
                </div>
            }

            <h3 class="h6 mt-2">Classes</h3>
            <table class="table table-sm mb-2">
                <thead>
                    <tr><th>Name</th><th class="text-end">V<sub>RefCru</sub> (km/h)</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var cc in c.Classes)
                {
                    @if (Model.EditClass == cc.Id)
                    {
                        <tr>
                            <td colspan="3">
                                <form method="post" asp-page-handler="UpdateClass" asp-route-id="@cc.Id" class="row g-2 align-items-end">
                                    <div class="col-md-4">
                                        <input asp-for="Class.Name" value="@cc.Name" class="form-control form-control-sm" />
                                        <span asp-validation-for="Class.Name" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-3">
                                        <input asp-for="Class.VRefCruKmh" value="@cc.VRefCruKmh" class="form-control form-control-sm" />
                                        <span asp-validation-for="Class.VRefCruKmh" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-4">
                                        <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                        <a asp-page="Index" class="btn btn-secondary btn-sm">Cancel</a>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td>@cc.Name</td>
                            <td class="text-end">@cc.VRefCruKmh</td>
                            <td class="text-end">
                                <a asp-page="/Gliders/Index" asp-route-classId="@cc.Id" class="btn btn-sm btn-outline-secondary">Fleet</a>
                                <a asp-page="/Entries/Index" asp-route-classId="@cc.Id" class="btn btn-sm btn-outline-secondary">Entries</a>
                                <a asp-page="Index" asp-route-editClass="@cc.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form method="post" asp-page-handler="DeleteClass" asp-route-id="@cc.Id" class="d-inline"
                                      onsubmit="return confirm('Delete this class and all its gliders, entries and tasks?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                @if (!c.Classes.Any() && Model.AddClassTo != c.Id)
                {
                    <tr><td colspan="3" class="text-muted">No classes yet.</td></tr>
                }
                </tbody>
            </table>

            @if (Model.AddClassTo == c.Id)
            {
                <form method="post" asp-page-handler="CreateClass" asp-route-competitionId="@c.Id" class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Class name</label>
                        <input asp-for="Class.Name" class="form-control form-control-sm" placeholder="e.g. Racing, Club" />
                        <span asp-validation-for="Class.Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">V<sub>RefCru</sub> (km/h)</label>
                        <input asp-for="Class.VRefCruKmh" class="form-control form-control-sm" />
                        <span asp-validation-for="Class.VRefCruKmh" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary btn-sm">Add class</button>
                        <a asp-page="Index" class="btn btn-secondary btn-sm">Cancel</a>
                    </div>
                </form>
            }
            else
            {
                <a asp-page="Index" asp-route-addClassTo="@c.Id" class="btn btn-sm btn-outline-primary">Add class</a>
            }
        </div>
    </div>
}

@if (Model.EditCompetition == 0)
{
    <div class="card mb-3 border-primary">
        <div class="card-body">
            <h2 class="h5">New competition</h2>
            <form method="post" asp-page-handler="CreateCompetition" class="row g-2 align-items-end">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="col-md-3">
                    <label class="form-label">Name</label>
                    <input asp-for="Competition.Name" class="form-control" />
                    <span asp-validation-for="Competition.Name" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Site</label>
                    <input asp-for="Competition.Site" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Start</label>
                    <input asp-for="Competition.StartDate" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">End</label>
                    <input asp-for="Competition.EndDate" class="form-control" />
                </div>
                <div class="col-md-2 form-check ms-2">
                    <input asp-for="Competition.MakeActive" class="form-check-input" />
                    <label asp-for="Competition.MakeActive" class="form-check-label">Active</label>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary btn-sm">Create competition</button>
                    <a asp-page="Index" class="btn btn-secondary btn-sm">Cancel</a>
                </div>
            </form>
        </div>
    </div>
}
else
{
    <a asp-page="Index" asp-route-editCompetition="0" class="btn btn-primary">New competition</a>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
