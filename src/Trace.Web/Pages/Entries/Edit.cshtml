@page "{id:int}"
@model Trace.Web.Pages.Entries.EditModel
@{
    ViewData["Title"] = "Edit entry";
}

<h1>Edit entry</h1>

<div class="row">
    <div class="col-md-7">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <h2 class="h5">Glider</h2>
            <div class="row g-2 mb-3">
                <div class="col-md-3">
                    <label asp-for="CompNo" class="form-label"></label>
                    <input asp-for="CompNo" class="form-control" />
                    <span asp-validation-for="CompNo" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Type" class="form-label"></label>
                    <input asp-for="Type" class="form-control" />
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Registration" class="form-label"></label>
                    <input asp-for="Registration" class="form-control" />
                    <span asp-validation-for="Registration" class="text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label asp-for="Handicap" class="form-label"></label>
                    <input asp-for="Handicap" class="form-control" />
                    <span asp-validation-for="Handicap" class="text-danger"></span>
                </div>
            </div>

            <h2 class="h5">Pilots</h2>
            @for (int i = 0; i < Trace.Web.Pages.Entries.EditModel.PilotSlots; i++)
            {
                var selected = i < Model.PilotIds.Length ? Model.PilotIds[i] : null;
                <div class="mb-2">
                    <label class="form-label">@(i == 0 ? "Primary (P1)" : $"Pilot {i + 1} (optional)")</label>
                    <select name="PilotIds[@i]" class="form-select">
                        <option value="">— none —</option>
                        @foreach (var p in Model.Pilots)
                        {
                            <option value="@p.Id" selected="@(selected == p.Id)">@p.Name</option>
                        }
                    </select>
                </div>
            }

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-page="Index" asp-route-classId="@Model.ClassId" class="btn btn-secondary">Back to entries</a>
            </div>
        </form>
    </div>

    <div class="col-md-5">
        <h2 class="h5">Loggers</h2>
        @if (!Model.Loggers.Any())
        {
            <p class="text-muted">No loggers recorded.</p>
        }
        else
        {
            <ul class="list-group mb-3">
            @foreach (var l in Model.Loggers)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>@l.LoggerId @(string.IsNullOrEmpty(l.Type) ? "" : $"({l.Type})")</span>
                    <form method="post" asp-page-handler="RemoveLogger" asp-route-loggerId="@l.Id" class="d-inline">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                    </form>
                </li>
            }
            </ul>
        }

        <form method="post" asp-page-handler="AddLogger">
            <input type="hidden" asp-for="Id" />
            <div class="row g-2">
                <div class="col">
                    <input asp-for="NewLoggerId" class="form-control" placeholder="Logger id" />
                </div>
                <div class="col">
                    <input asp-for="LoggerType" class="form-control" placeholder="Type (optional)" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-outline-primary">Add logger</button>
                </div>
            </div>
            <span asp-validation-for="NewLoggerId" class="text-danger"></span>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
