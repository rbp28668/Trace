@page
@model Trace.Web.Pages.Entries.IndexModel
@{
    ViewData["Title"] = "Entries";
    var comp = Model.Class!.Competition!;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Competitions/Index">Competitions</a></li>
        <li class="breadcrumb-item"><a asp-page="/Competitions/Index">@comp.Name</a></li>
        <li class="breadcrumb-item active">@Model.Class.Name — Entries</li>
    </ol>
</nav>

<h1>Entries — @Model.Class.Name</h1>

<p>
    <a asp-page="Create" asp-route-classId="@Model.Class.Id" class="btn btn-primary">New entry</a>
    <a asp-page="/Gliders/Import" asp-route-classId="@Model.Class.Id" class="btn btn-outline-primary">Import CSV</a>
</p>

@if (!Model.Entries.Any())
{
    <div class="alert alert-info">No entries yet. Add a glider and its pilot(s), or import an entrants CSV.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr><th>Glider</th><th>Type</th><th class="text-end">Handicap</th><th>Pilots</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var en in Model.Entries)
        {
            <tr>
                <td>@en.Glider!.CompNo</td>
                <td>@en.Glider!.Type</td>
                <td class="text-end">@en.Glider!.Handicap</td>
                <td>@string.Join(", ", en.Pilots.OrderBy(p => p.Order).Select(p => p.Pilot!.Name))</td>
                <td class="text-end">
                    <a asp-page="Edit" asp-route-id="@en.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@en.Id"
                          asp-route-classId="@Model.Class.Id" class="d-inline"
                          onsubmit="return confirm('Remove this entry?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
