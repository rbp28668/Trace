@page
@model Trace.Web.Pages.Tasks.CreateModel
@{
    ViewData["Title"] = "New task";
}

<h1>New task — Day @Model.Day!.DayNo, @Model.Class!.Name</h1>

<form method="post" class="col-md-6">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="DayId" />
    <input type="hidden" asp-for="ClassId" />
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" placeholder="e.g. Task 1 Racer" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="TaskType" class="form-label"></label>
        <select asp-for="TaskType" class="form-select" style="max-width: 8rem;">
            <option>A</option>
            <option>B</option>
            <option>C</option>
        </select>
        <span asp-validation-for="TaskType" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Create &amp; add turnpoints</button>
    <a asp-page="Index" asp-route-dayId="@Model.DayId" asp-route-classId="@Model.ClassId" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
